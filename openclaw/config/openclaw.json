{
  "gateway": {
    "bind": "lan",
    "controlUi": {
      "allowedOrigins": [
        "https://openclaw.${DOMAIN_NAME}"
      ],
      "allowInsecureAuth": true
    },
    "auth": {
      "mode": "trusted-proxy",
      "trustedProxy": {
        "userHeader": "Remote-User"
      }
    },
    "trustedProxies": [
      "127.0.0.1",
      "::1",
      "172.16.0.0/12",
      "10.0.0.0/8",
      "192.168.0.0/16"
    ]
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "allowlist",
      "allowFrom": ["469700553"],
      "groupPolicy": "disabled",
      "streaming": "partial",
      "replyToMode": "first",
      "chunkMode": "newline",
      "actions": {
        "sticker": true
      },
      "network": {
        "dangerouslyAllowPrivateNetwork": true
      },
      "execApprovals": {
        "enabled": false
      }
    }
  },
  "models": {
    "providers": {
      "ollama": {
        "baseUrl": "http://ollama:11434",
        "api": "ollama",
        "apiKey": "ollama-local",
        "models": [
          {
            "id": "qwen3.5:2b",
            "name": "Qwen 3.5 2B",
            "contextWindow": 32768,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      },
      "model": {
        "primary": "ollama/qwen3.5:2b"
      },
      "sandbox": {
        "mode": "all",
        "backend": "docker",
        "scope": "agent",
        "workspaceAccess": "rw",
        "docker": {
          "image": "openclaw-sandbox:bookworm-slim",
          "binds": [
            "/data:/data:rw",
            "/data/openclaw/playwright-cache:/home/sandbox/.cache/ms-playwright:ro"
          ],
          "dangerouslyAllowExternalBindSources": true,
          "network": "internal"
        }
      }
    }
  },
  "tools": {
    "sandbox": {
      "tools": {
        "alsoAllow": ["browser", "canvas", "nodes", "cron", "gateway", "telegram"]
      }
    },
    "elevated": {
      "enabled": true,
      "allowFrom": {
        "webchat": ["*"],
        "telegram": ["469700553"]
      }
    }
  }
}
